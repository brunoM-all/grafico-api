{
  "name": "grafico-api",
  "version": "1.0.0",
  "description": "API de geração de gráficos de barras com visual escuro",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "watch:commit": "node scripts/auto-commit.js",
    "dev:full": "concurrently \"docker-compose up\" \"npm run watch:commit\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "chartjs-node-canvas": "^5.0.0",
    "chart.js": "^4.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.1.0"
  }
}
